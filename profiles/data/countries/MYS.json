onal policy document","version":"NA","doc_type":"National policy document","status":"Active","area":"Net zero target","scope":"Overall mitigation target","ghg":"GHG","type":"GHG: Fixed level","conditionality":"Unclear conditionality","year":"2050 at earliest","content":null,"page":null},{"doc_id":81468,"document":"Third Generation NDC","version":"NDC 3.0","doc_type":"NDC","status":"Active","area":"Overall mitigation target","scope":"Overall mitigation target","ghg":"GHG","type":"GHG: Fixed level","conditionality":"Unconditional","year":2035,"content":"Malaysia intends to achieve an absolute reduction of 15–30 million tonnes of CO₂ equivalent (MtCO₂eq) by 2035 from the peak level. This comprises an unconditional reduction of up to 20 MtCO₂eq, with a further 10 MtCO₂eq reduction conditional upon the provision of climate finance, technology transfer, and capacity-building support from international sources.","page":1},{"doc_id":81468,"document":"Third Generation NDC","version":"NDC 3.0","doc_type":"NDC","status":"Active","area":"Overall mitigation target","scope":"Overall mitigation target","ghg":"GHG","type":"GHG: Fixed level","conditionality":"Conditional","year":2035,"content":"with a further 10 MtCO₂eq reduction conditional upon the provision of climate finance, technology transfer, and capacity-building support from international sources.","page":1},{"doc_id":81468,"document":"Third Generation NDC","version":"NDC 3.0","doc_type":"NDC","status":"Active","area":"Overall mitigation target","scope":"Overall mitigation target","ghg":"GHG","type":"GHG: BAU","conditionality":"Conditional","year":2035,"content":"Malaysia is expected to peak its GHG emissions between 2029 and 2034;","page":1}],"measures":[{"doc_id":81468,"document":"Third Generation NDC","version":"NDC 3.0","doc_type":"NDC","status":"Active","category":"Transport system improvements","purpose":"Improve infrastructure","instrument":"Expansion of infrastructure","asi":["Shift"],"quote":"Major investments are