:false,"benefits":false,"just_transition":null},"counts":{"targets":1,"measures":0,"adaptation":0,"benefits":0}}],"active":{"ndc_version":"NDC 3.0","lts":true},"targets":[{"doc_id":17678,"document":"First Generation NDC","version":"NDC 1.0","doc_type":"NDC","status":"Archived","area":"Overall mitigation target","scope":"Overall mitigation target","ghg":"GHG","type":"GHG: Base year","conditionality":"Unconditional","year":2030,"content":"30% below 2005 levels by 2030","page":"n/a"},{"doc_id":17680,"document":"Second Generation NDC","version":"NDC 2.0","doc_type":"NDC","status":"Archived","area":"Overall mitigation target","scope":"Overall mitigation target","ghg":"GHG","type":"GHG: Fixed level","conditionality":"Unconditional","year":2050,"content":"New Zealand confirmed its commitment to ambitious national action through legislation enacted in late 2019 that set a new domestic target to reduce net emissions of greenhouse gases (other than biogenic methane) to zero by 2050.","page":1},{"doc_id":17679,"document":"Climate Change Response (Zero Carbon) Amendment Act 2019","version":"NA","doc_type":"Other","status":"Active","area":"Overall mitigation target","scope":"Overall mitigation target","ghg":"GHG","type":"GHG: Fixed level","conditionality":"Unconditional","year":2050,"content":"The target for emissions reduction (the 2050 target) requires that net accounting emissions of greenhouse gases in a calendar year, other than biogenic methane, are zero by the calendar year beginning on 1 January 2050 and for each subsequent calendar year.","page":null},{"doc_id":23933,"document":"Second Generation NDC","version":"NDC 2.1","doc_type":"NDC","status":"Archived","area":"Overall mitigation target","scope":"Overall mitigation target","ghg":"GHG","type":"GHG: Base year","conditionality":"Unconditional","year":2030,"content":"Emissions will be reduced by 50 per cent below gross 2005 levels by 2030, which corresponds to a 41 per cent reduction when managed using a multi-year emissions budget","page":2},{"doc_id":23933,"document":"Second Generation NDC","version":"NDC 2.1","doc_type":"NDC","status":"Archived","area":"Net zero target","scope":"Overall mitigation target","ghg":"GHG","type":"GHG: Fixed level","conditionality":"Unclear conditionality","year":2050,"content":"New Zealand’s domestic 2050 target  under the CCRA  places an emphasis on long-lived gases. The target is to reduce greenhouse gas emissions to net zero by 2050 (excluding biogenic methane for which the target is 24-47 per cent below 2017 levels).","page":5},{"doc_id":26786,"document":"LTS","version":"LTS 1.0","doc_type":"LTS","status":"Active","area":"Overall mitigation target","scope":"Overall mitigation target","ghg":"GHG","type":"GHG: Base year","conditionality":"Unconditional","year":2050,"content":"By 2050, long-lived greenhouse gases are net zero and biogenic methane emissions are 24–47% below 2017 levels, and 10% below by 2030","page":13},{"doc_id":26786,"document":"LTS","version":"LTS 1.0","doc_type":"LTS","status":"Active","area":"Transport sector mitigation target","scope":"Sector-wide","ghg":"GHG","type":"GHG: Fixed level","conditionality":"Unconditional","year":2050,"content":"Aotearoa will reduce transport emissions to net zero by 2050, while building a healthy, safe, equitable and accessible transport system","page":45},{"doc_id":43906,"document":"Third Generation NDC","version":"NDC 3.0","doc_type":"NDC","status":"Active","area":"Overall mitigation target","scope":"Overall mitigation target","ghg":"GHG","type":"GHG: Base year","conditionality":"Unconditional","year":2035,"content":"To reduce net greenhouse gas emissions to 51–55 per cent below gross 2005 levels by 2035 (between 38.98 and 42.44 Mt CO2-e).","page":2},{"doc_id":43906,"document":"Third Generation NDC","version":"NDC 3.0","doc_type":"NDC","status":"Active","area":"Net zero target","scope":"Overall mitigation target","ghg":"GHG","type":"GHG: Base year","conditionality":"Unconditional","year":2050,"c