rue,"target_summary":"non-GHG target","ghg_target_type":"No GHG transport target","adaptation_target":false,"mitigation_measures":true,"adaptation_measures":true,"benefits":false,"just_transition":null},"counts":{"targets":2,"measures":9,"adaptation":1,"benefits":0}},{"id":79395,"type":"LTS","name":"LTS","version":"LTS 2.0","generation":null,"date":"2025-06-16","status":"Active","url":null,"transport":{"has_content":true,"mitigation_target":true,"target_summary":"GHG and non-GHG target","ghg_target_type":"GHG unconditional only","adaptation_target":false,"mitigation_measures":true,"adaptation_measures":false,"benefits":false,"just_transition":null},"counts":{"targets":9,"measures":2,"adaptation":0,"benefits":0}}],"active":{"ndc_version":"NDC 2.0","lts":true},"targets":[{"doc_id":17584,"document":"First Generation NDC","version":"NDC 1.0","doc_type":"NDC","status":"Archived","area":"Overall mitigation target","scope":"Overall mitigation target","ghg":"GHG","type":"GHG: Base year","conditionality":"Unclear conditionality","year":null,"content":"La ambición de Guinea Ecuatorial es reducir en un 20% de sus emisiones para el año 2030, con respecto a los niveles de 2010; a fin de alcanzar una reducción de 50% para el año 2050.","page":8},{"doc_id":17584,"document":"First Generation NDC","version":"NDC 1.0","doc_type":"NDC","status":"Archived","area":"Overall mitigation target","scope":"Overall mitigation target","ghg":"GHG","type":"GHG: BAU","conditionality":"Unconditional","year":2030,"content":"20% below 2030 BAU","page":"n/a"},{"doc_id":32499,"document":"Second Generation NDC","version":"NDC 2.0","doc_type":"NDC","status":"Active","area":"Overall mitigation target","scope":"Overall mitigation target","ghg":"GHG","type":"GHG: Base year","conditionality":"Unconditional","year":2030,"content":"La ambición de Guinea Ecuatorial en su CDN actualizada se ha aumentado y tiene el objetivo de reducir las emisiones en un 35% para el año 2030, con la meta de alcanzar el 50% para el 2050, con una reducción total de 379.291,54 Gg CO2eq, con referencia al año 2019 (446.215,38 Gg CO2eq). La próxima actualización será en el año 2027.","page":5},{"doc_id":32499,"document":"Second Generation NDC","version":"NDC 2.0","doc_type":"NDC","status":"Active","area":"Energy sector target","scope":"Sector-wide","ghg":"GHG","type":"GHG: BAU","conditionality":"Unclear conditionality","year":2050,"content":"Reducción de un mínimo del 50% de las emisiones de GEI asociados a la cadena de valor de los sectores del petróleo y gas antes del 2050.","page":27},{"doc_id":32499,"document":"Second Generation NDC","version":"NDC 2.0","doc_type":"NDC","status":"Active","area":"Overall mitigation target","scope":"Overall mitigation target","ghg":"GHG","type":"GHG: Base year","conditionality":"Unclear conditionality","year":2050,"content":"con la meta de alcanzar el 50% para el 2050,","page":null},{"doc_id":41738,"document":"Archived LTS 1.0","version":"LTS 1.0","doc_type":"LTS","status":"Archived","area":"Transport sector mitigation target","scope":"Subsector targets","ghg":"Non GHG","type":"Zero emission vehicle targets","conditionality":"Unconditional","year":2050,"content":"En 2050, la totalidad de los vehículos públicos son no emisores netos de GEI, así como un porcentaje significativo de los vehículos privados.","page":28},{"doc_id":41738,"document":"Archived LTS 1.0","version":"LTS 1.0","doc_type":"LTS","status":"Archived","area":"Transport sector mitigation target","scope":"Subsector targets","ghg":"Non GHG","type":"Mode share targets","conditionality":"Unconditional","year":2050,"content":"El mayor uso del transporte colectivo reduce la utilización de los vehículos privados al 50% del total de viajes en 2050","page":29},{"doc_id":79395,"document":"LTS","version":"LTS 2.0","doc_type":"LTS","status":"Active","area":"Overall mitigation target","scope":"Overall mitigation target","ghg":"GHG","type":"GHG: Base year","conditionality":"Unconditional","year":2035,"content":"Este escenario incluye metas de reducción de emisiones brutas de GEI alineadas con la Contribución Determinada a Nivel Nacional (CDN), estableciendo una disminución del 35 % para 2035 y del 50 % para 2050, en comparación con los niveles de emisiones del año 2019","page":3},{"doc_id":79395,"document":"LTS","version":"LTS 2.0","doc_type":"LTS","status":"Active","area":"Overall mitigation target","scope":"Overall mitigation target","ghg":"GHG","type":"GHG: Base year","conditionality":"Unconditional","year":2050,"content":"Este escenario incluye metas de reducción de emisiones brutas de GEI alineadas con la Contribución Determinada a Nivel Nacional (CDN), estableciendo una disminución del 35 % para 2035 y del 50 % para 2050, en comparación con los niveles de emisiones del año 2019","page":3},{"doc_id":79395,"document":"LTS","version":"LTS 2.0","doc_type":"LTS","status":"Active","area":"Energy sector target","scope":"Sector-wide","ghg":"Non GHG","type":"Renewable energy","conditionality":"Unconditional","year":2035,"content":"El escenario Mitigación contempla una descarbonización profunda del subsector de la Industria de la energía, alcanzando un porcentaje de generación eléctrica renovable del 77 % en 2035 y del 100 % en 2049, respectivamente.","page":45},{"doc_id":79395,"document":"LTS","version":"LTS 2.0","doc_type":"LTS","status":"Active","area":"Energy sector target","scope":"Sector-wide","ghg":"Non GHG","type":"Renewable energy","conditionality":"Unconditional","year":2049,"content":"El escenario Mitigación contempla una descarbonización profunda del subsector de la Industria de la energía, alcanzando un porcentaje de generación eléctrica renovable del 77 % en 2035 y del 100 % en 2049, respectivamente.","page":45},{"doc_id":79395,"document":"LTS","version":"LTS 2.0","doc_type":"LTS","status":"Active","area":"Transport sector mitigation target","scope":"Sector-wide","ghg":"Non GHG","type":"Mode share targets","conditionality":"Unconditional","year":2050,"content":"Asimismo, se ha tenido en cuenta una leve reducción en la distancia media anual recorrida por vehículos utilitarios, motocicletas, SUVs, furgonetas y camiones de mercancías. Esta disminución se debe a una mayor distancia media recorrida por autobuses, al uso de medios activos de movilidad (ej., bicicleta), así como a una mejora en la gestión del transporte de mercancías.","page":46},{"doc_id":79395,"document":"LTS","version":"LTS 2.0","doc_type":"LTS","status":"Active","area":"Transport sector mitigation target","scope":"Subsector targets","ghg":"Non GHG","type":"Vehicle efficiency targets","conditionality":"Unconditional","year":2050,"content":"También se considera un ligero descenso anual del 0.25 % en el consumo de los vehículos de gasolina, motivado por la implementación de un plan nacional de renovación del parque vehicular.","page":46},{"doc_id":79395,"document":"LTS","version":"LTS 2.0","doc_type":"LTS","status":"Active","area":"Transport sector mitigation target","scope":"Subsector targets","ghg":"Non GHG","type":"Zero emission vehicle targets","conditionality":"Unconditional","year":2050,"content":"Se estima una electrificación progresiva del transporte rodado, alcanzando una electrificación del 100 % de los autobuses y del 35 % del resto de vehículos para el año 2050.","page":46},{"doc_id":79395,"document":"LTS","version":"LTS 2.0","doc_type":"LTS","status":"Active","area":"Transport sector mitigation target","scope":"Subsector targets","ghg":"GHG","type":"GHG: Fixed level","conditionality":"Unconditional","year":2050,"content":"En cuanto a la aviación doméstica, se ha considerado que, en el 2050, la totalidad del combustible utilizado es catalogado como SAF, alcanzando emisiones netas cero sin necesidad de implementación de acciones adicionales de compensación","page":46},{"doc_id":79395,"document":"LTS","version":"LTS 2.0","doc_type":"LTS","status":"Active","area":"Overall mitigation target","scope":"Overall mitigation target","ghg":"GHG","type":"GHG: Fixed level","conditionality":"Unconditional","year":2050,"content":"De este modo, bajo el escenario Mitigación, Guinea Ecuatorial logra reducir en un 420 % sus emisiones netas anuales totales entre 2019 y 2050, alcanzando un saldo de carbono negativo en 2050 con emisiones netas anuales de -7.300 Gg CO2eq","page":73}],"measures":[{"doc_id":17584,"document":"First Generation NDC","version":"NDC 1.0","doc_type":"NDC","status":"Archived","category":"Transport system improvements","purpose":"Improve infrastructure","instrument":"Infrastructure improvements","asi":["Improve"],"quote":"Improvement of (..) road traffic (...) infrastructures","page":null,"modes":["Road"],"geography":[],"measure_status":null},{"doc_id":17584,"document":"First Generation NDC","version":"NDC 1.0","doc_type":"NDC","status":"Archived","category":"Aviation and maritime","purpose":"Promote improvements in aviation","instrument":"General aviation improvements","asi":["Improve"],"quote":"Acquisition of aircraft equipped with high technology\n\nContinuation of the modernization of airport infrastructures","page":null,"modes":["Aviation"],"geography":[],"measure_status":null},{"doc_id":17584,"document":"First Generation NDC","version":"NDC 1.0","doc_type":"NDC","status":"Archived","category":"Aviation and maritime","purpose":"Promote improvements in shipping","instrument":"Port infrastructure improvements","asi":["Improve"],"quote":"Continuation of the modernization (…) port infrastructures","page":null,"modes":["Water"],"geography":[],"measure_status":null},{"doc_id":17584,"document":"First Generation NDC","version":"NDC 1.0","doc_type":"NDC","status":"Archived","category":"Mode shift and demand management","purpose":"Public transport improvement","instrument":"General public transport improvement","asi":["Shift"],"quote":"Promotion of collective urban and interurban transport for the reduction of Emissions due to the proliferation of individual transport","page":null,"modes":[],"geography":["Urban","I